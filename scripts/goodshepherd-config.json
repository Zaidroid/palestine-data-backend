{
  "api_base": "https://goodshepherdcollective.org/api",
  "rate_limit_ms": 1000,
  "max_retries": 3,
  "backoff_multiplier": 2,
  "baseline_date": "2023-10-07",
  "endpoints": {
    "prisoners": "/prisoner_data.json",
    "child_prisoners": "/child_prisoners.json",
    "demolitions": "/home_demolitions.json",
    "healthcare_attacks": "/healthcare_attacks.json",
    "westbank_incidents": "/wb_data.json",
    "ngo_data": "/ngo_data.json"
  },
  "fallback_files": {
    "child_prisoners": "src/data/minors-pre.json",
    "prisoners": "src/data/spi-pre.json"
  },
  "output_dir": "public/data/goodshepherd",
  "categories": {
    "child_prisoners": ["12 to 15 year olds", "Administrative detention", "Detention", "Female"],
    "detention_types": ["administrative", "criminal", "military_court"]
  }
}
