# Environment Configuration for Palestine Data Backend
# Copy this file to .env and configure values.

# Runtime
NODE_ENV=development
PORT=7860
LOG_LEVEL=info
DATA_DIR=./data

# Cross-service URL (Express → FastAPI alerts service)
ALERTS_API_URL=http://alerts:8080

# Customer API-key registry (SQLite). Same path is mounted into the alerts container.
KEYS_DB_PATH=./data/keys.db

# API Keys (optional — leave blank to use public access)
HDX_API_KEY=
WORLDBANK_API_KEY=
WHO_API_KEY=

# Fetcher tuning
FETCH_TIMEOUT=30000
MAX_RETRIES=3

# Observability — leave SENTRY_DSN blank to disable error reporting.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
