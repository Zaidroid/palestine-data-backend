# ── Telegram ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
# Log in → API development tools → Create app
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+970XXXXXXXXX

# Comma-separated channel usernames WITHOUT the @ symbol
# Example: QudsN,wafanews,palinfo,nablus_now
TELEGRAM_CHANNELS=channel1,channel2,channel3
CHECKPOINT_CHANNELS=
GAZA_BULLETIN_CHANNELS=

# ── Location priority ─────────────────────────────────────────────────────────
# Alerts mentioning this city will be classified as CRITICAL severity
YOUR_CITY_AR=نابلس
YOUR_CITY_EN=Nablus

# ── API security ──────────────────────────────────────────────────────────────
# REQUIRED. The service refuses to boot if this is unset, shorter than 16 chars,
# or set to a known dev default ("dev-secret-change-me", "changeme", "secret").
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=/data/alerts.db
MAX_ALERTS_STORED=20000

# Customer API-key registry (shared SQLite mounted from the Node side, read-only)
KEYS_DB_PATH=/app/data/keys.db

# ── Observability ─────────────────────────────────────────────────────────────
# Leave SENTRY_DSN blank to disable error reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
